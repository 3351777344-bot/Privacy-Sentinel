# Frontend origins allowed to call the local API, separated by commas.
GUARDIANHUB_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Upload and retention limits.
GUARDIANHUB_MAX_IMAGE_BYTES=10485760
GUARDIANHUB_MAX_CODE_BYTES=1048576
GUARDIANHUB_MAX_DOC_BYTES=10485760
GUARDIANHUB_MAX_DOC_TOTAL_BYTES=26214400
GUARDIANHUB_MAX_DOC_FILES=8
GUARDIANHUB_MAX_IMAGE_PIXELS=25000000
GUARDIANHUB_RETENTION_HOURS=24

# Only enable this for a deterministic presentation without real OCR.
GUARDIANHUB_DEMO_MODE=false

# Local privacy agent engines. External image analysis stays disabled by default.
# Privacy detection engine: "ocr" (local only), "agent" (local + face), "hybrid" (local + Qwen VL), "vision_api" (Qwen VL first, local fallback)
GUARDIANHUB_PRIVACY_ENGINE=agent
GUARDIANHUB_OCR_ENGINE=rapidocr
GUARDIANHUB_QR_ENGINE=opencv
GUARDIANHUB_FACE_ENGINE=disabled
GUARDIANHUB_FACE_MODEL_PATH=
GUARDIANHUB_DEFAULT_MASK_TYPE=mosaic
GUARDIANHUB_ENABLE_EXTERNAL_IMAGE_ANALYSIS=false

# Qwen VL external API for enhanced image privacy detection (optional).
GUARDIANHUB_QWEN_ENABLED=false
GUARDIANHUB_QWEN_API_KEY=sk-xxxxxxxxxxxxxxxx
GUARDIANHUB_QWEN_MODEL=qwen3-vl-flash
GUARDIANHUB_QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
GUARDIANHUB_QWEN_TIMEOUT_SECONDS=35
GUARDIANHUB_QWEN_IMAGE_MAX_SIDE=1280
GUARDIANHUB_QWEN_MAX_TOKENS=1536

# Code Guardian engine: "rule" (local regex only) or "deepseek" (DeepSeek AI, default)
GUARDIANHUB_CODE_ENGINE=deepseek
GUARDIANHUB_DEEPSEEK_ENABLED=false
GUARDIANHUB_DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
GUARDIANHUB_DEEPSEEK_MODEL=deepseek-v4-flash
GUARDIANHUB_DEEPSEEK_API_BASE=https://api.deepseek.com
